{
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "functions": {
    "api/pos.js": {
      "maxDuration": 60
    },
    "api/upload-image.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/pos",
      "destination": "/api/pos"
    },
    {
      "source": "/api/upload-image",
      "destination": "/api/upload-image"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ],
  "_note": "redeploy-with-correct-github-token"
}