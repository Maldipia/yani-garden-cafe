{
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "functions": {
    "api/pos.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/pos", "destination": "/api/pos" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
