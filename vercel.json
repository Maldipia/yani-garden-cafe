{
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "functions": {
    "api/pos.js": {
      "maxDuration": 60
    },
    "api/upload-image.js": {
      "maxDuration": 30
    },
    "api/online-order.js": {
      "maxDuration": 30
    },
    "api/upload-proof.js": {
      "maxDuration": 30
    },
    "api/sheets-sync.js": {
      "maxDuration": 30
    },
    "api/health.js": {
      "maxDuration": 15
    },
    "api/sync-menu.js": {
      "maxDuration": 15
    },
    "api/queue-status.js": {
      "maxDuration": 10
    },
    "api/daily-report.js": {
      "maxDuration": 30
    },
    "api/payment-proof.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/pos",
      "destination": "/api/pos"
    },
    {
      "source": "/api/upload-image",
      "destination": "/api/upload-image"
    },
    {
      "source": "/api/online-order",
      "destination": "/api/online-order"
    },
    {
      "source": "/api/upload-proof",
      "destination": "/api/upload-proof"
    },
    {
      "source": "/api/queue-status",
      "destination": "/api/queue-status"
    },
    {
      "source": "/api/sheets-sync",
      "destination": "/api/sheets-sync"
    },
    {
      "source": "/api/health",
      "destination": "/api/health"
    },
    {
      "source": "/api/sync-menu",
      "destination": "/api/sync-menu"
    },
    {
      "source": "/api/daily-report",
      "destination": "/api/daily-report"
    },
    {
      "source": "/kitchen",
      "destination": "/kitchen.html"
    },
    {
      "source": "/api/payment-proof",
      "destination": "/api/payment-proof"
    },
    {
      "source": "/track",
      "destination": "/track.html"
    },
    {
      "source": "/track-order",
      "destination": "/track.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/(.*\\.html|)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/daily-report",
      "schedule": "55 15 * * *"
    }
  ]
}